### WhatsApp Cloud API (Meta)
# WA_PHONE_NUMBER_ID is the phone number id for your WhatsApp Business Cloud account
WA_PHONE_NUMBER_ID=YOUR_PHONE_NUMBER_ID
WA_ACCESS_TOKEN=YOUR_LONG_LIVED_TOKEN
# International number without + (e.g. 254702820845)
NOTIFY_TO=254702820845

### Twilio alternative
# Uncomment and set PROVIDER to 'twilio' if you prefer Twilio
WA_PROVIDER=whatsapp_cloud
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Server port
PORT=3001
